# ─── GreenNode MaaS — LLM ────────────────────────────────────────────────────
# Lấy API key tại: https://console.greennode.ai → API Keys
LLM_API_KEY=your-greennode-maas-api-key
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=qwen/qwen3-5-27b

# ─── Google Sheets (optional, đọc dữ liệu CTKM realtime) ─────────────────────
